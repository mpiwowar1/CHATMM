DB_URL=jdbc:postgresql://<host>:<port>/<db_name>
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Secret key should be a base64 encoded string (256 bits minimum required)
JWT_SECRET=your_jwt_secret_key_base64_encoded
JWT_TOKEN_EXPIRATION=900000
REFRESH_TOKEN_EXPIRATION=2592000000

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173